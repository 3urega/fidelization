# --- Web / API ---
NEXT_PUBLIC_API_URL=http://localhost:3000

# Auth (obligatorio en dev: mín. 16 caracteres)
AUTH_SECRET=change-me-to-a-long-random-secret

# Platform app — Google Sign-In (Web client ID from Google Cloud Console)
# Ver docs/backend/external-services-env.md
# GOOGLE_CLIENT_ID=123456789.apps.googleusercontent.com
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=123456789.apps.googleusercontent.com
# Optional E2E: real GIS id_token for verify:platform-app-google-oauth
# GOOGLE_OAUTH_E2E_ID_TOKEN=

# Platform superadmin (seed only — no public register)
SUPERADMIN_EMAIL=superadmin@platform.local
SUPERADMIN_PASSWORD=change-me-superadmin

# Multi-tenant subdomain resolution (issue #5): cafe-demo.localhost:3000
APP_DOMAIN=localhost
# Owner dashboard scan windows (IANA timezone; default Europe/Madrid)
# APP_TIMEZONE=Europe/Madrid
# Client-side redirect after login (must match APP_DOMAIN)
NEXT_PUBLIC_APP_DOMAIN=localhost
# Production only: shared session across apex + subdomains (defaults to .${APP_DOMAIN})
# SESSION_COOKIE_DOMAIN=.platform.example.com

# Billing demo en local (botones FREE/PREMIUM en /profile)
ALLOW_DEMO_BILLING=1

# Dev/staging: desactiva gates de plan tenant (promociones Pro+, límite empleados, etc.)
# Ignorado en NODE_ENV=production. Alternativa: asignar plan Pro en /onboarding/plan
DISABLE_TENANT_PLAN_GATES=1

# Stripe Checkout (issue #32 — Pro/Premium; Basic sigue con PATCH)
# Ver docs/backend/external-services-env.md
STRIPE_SECRET_KEY=sk_test_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
STRIPE_PRICE_PRO_MONTHLY=price_test_pro_monthly
STRIPE_PRICE_PREMIUM_MONTHLY=price_test_premium_monthly

# Build estático Capacitor (solo build móvil)
# CAPACITOR_STATIC=1

# Capacitor
# CAPACITOR_APP_ID=com.eurega.fidelization
# CAPACITOR_APP_NAME=3urega
# Dev: load WebView from dev server instead of out/ (live reload)
# CAPACITOR_SERVER_URL=http://10.0.2.2:3000
# Static export for native shell — set automatically by build-capacitor.sh
# NEXT_PUBLIC_CAPACITOR_STATIC=1

# Postgres (compose local)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=codely
# POSTGRES_PASSWORD=c0d3ly7v
# POSTGRES_DB=postgres

# Prisma Postgres (managed — set via `prisma postgres link`)
DATABASE_URL=

# Google Play Billing (servidor)
# GOOGLE_PLAY_PACKAGE_NAME=com.example.starter
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_PLAY_SUBSCRIPTION_PRODUCT_IDS=premium_monthly
